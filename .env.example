# Postgres
POSTGRES_USER=upstreamhub
POSTGRES_PASSWORD=change-me
POSTGRES_DB=upstreamhub
POSTGRES_PORT=54329

# Backend
UPSTREAMHUB_SERVER_PORT=8418
UPSTREAMHUB_DATABASE_HOST=postgres
UPSTREAMHUB_DATABASE_PORT=5432
UPSTREAMHUB_DATABASE_USER=upstreamhub
UPSTREAMHUB_DATABASE_PASSWORD=change-me
UPSTREAMHUB_DATABASE_NAME=upstreamhub

# 主密钥（任意长度，至少 32 字节随机串），用于 AES-GCM 加密敏感字段。
# 修改后既有数据会无法解密，请务必妥善保存。
APP_SECRET=please-change-me-to-a-long-random-secret-32bytes-min

# 后台登录账号 / 密码（也可写在 backend/config.yaml 的 auth 段）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-please
# token 签名密钥；留空时回退使用 APP_SECRET
AUTH_TOKEN_SECRET=
